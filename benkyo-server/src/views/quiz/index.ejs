<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Available Quizzes</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% quizes.forEach(quiz => { %>
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold mb-2"><%= quiz.title %></h2>
                <p class="text-gray-600 mb-4"><%= quiz.description %></p>
                <p class="text-sm text-gray-500 mb-4">Questions: <%= quiz.questions.length %></p>
                <a href="/quiz/<%= quiz._id %>/take" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                    Take Quiz
                </a>
            </div>
        <% }); %>
    </div>
</div>